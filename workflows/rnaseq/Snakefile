    params:
        java_args="-Xmx20g",  # [disable for test]
        # java_args='-Xmx2g',  # [enable for test]
        strand_arg={
            "unstranded": "STRAND=NONE ",
            "fr-firststrand": "STRAND=SECOND_READ_TRANSCRIPTION_STRAND ",
