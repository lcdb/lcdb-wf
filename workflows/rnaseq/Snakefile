        mem="16g",
        runtime="2h",
    shell:
        "samtools sort -n -o {output} {input}"


rule featurecounts:
    input:
        annotation=f"{REFERENCES}/annotation.gtf.gz",
        bam=expand(
            (
                rules.namesorted_bam.output
                if is_paired
                else rules.markduplicates.output.bam
            ),
            sample=SAMPLES,
        ),
    output:
        "data/rnaseq_aggregation/featurecounts.txt",
    log:
        "data/rnaseq_aggregation/featurecounts.txt.log",
    threads: 8
    resources:
        mem="16g",
        runtime="2h",
    params:
        strand_arg={
            "unstranded": "-s0 ",
            "fr-firststrand": "-s2 ",
            "fr-secondstrand": "-s1 ",
        }[config["stranded"]],
    run:
        p_arg = "-p --countReadPairs " if is_paired else ""
        shell(
            "featureCounts "
            "{params.strand_arg} "
            "{p_arg} "
            "-T {threads} "
            "-a {input.annotation} "
            "-o {output} "
            "{input.bam} "
            "&> {log}"
        )


