        runtime="2h",
    params:
        urls=config["fasta"]["url"],
        postprocess=config["fasta"].get("postprocess", None)
    run:
        utils.download_and_postprocess(
            urls=params.urls,
            postprocess=params.postprocess,
            outfile=output[0],
            log=log,
        )


